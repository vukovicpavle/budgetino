{
  "name": "budgetino",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:mobile": "turbo dev --filter=mobile",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "node -e \"process.exit(0)\"",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "clean": "turbo clean",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status"
  },
  "prettier": "@budgetino/prettier-config",
  "devDependencies": {
    "@budgetino/prettier-config": "workspace:*",
    "prettier": "^3.5.3",
    "turbo": "^2.9.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "@types/react": "^19"
    }
  }
}
