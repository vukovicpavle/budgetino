{
  "name": "mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "expo export --platform all --output-dir expo-dist",
    "eas-build:development": "pnpm exec eas build --platform all --profile development",
    "eas-build:preview": "pnpm exec eas build --platform all --profile preview",
    "eas-build:production": "pnpm exec eas build --platform all --profile production",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "rimraf .expo expo-dist"
  },
  "dependencies": {
    "@budgetino/auth": "workspace:*",
    "@budgetino/shared": "workspace:^",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~55.0.0",
    "expo-auth-session": "~55.0.12",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~55.0.12",
    "expo-linking": "~55.0.0",
    "expo-localization": "~55.0.11",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.2.4",
    "expo-status-bar": "~2.0.1",
    "expo-web-browser": "~55.0.0",
    "i18next": "^26.0.3",
    "nativewind": "^4.1",
    "react": "18.3.1",
    "react-i18next": "^17.0.2",
    "react-native": "0.77.3",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@budgetino/eslint-config": "workspace:*",
    "@budgetino/tailwind-config": "workspace:*",
    "@budgetino/typescript-config": "workspace:*",
    "@types/react": "^19",
    "eas-cli": "18.4.0",
    "eslint": "^9",
    "rimraf": "^5.0.10",
    "tailwindcss": "^3.4",
    "typescript": "^5.7.3"
  }
}
