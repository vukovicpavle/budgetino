# =============================================================================
# Budgetino — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Base URL used for absolute links (e.g. in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase — Public (safe to expose to the browser)
# -----------------------------------------------------------------------------
# Your Supabase project URL.
# Local:  http://127.0.0.1:54321
# Cloud:  https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Your Supabase project anonymous/public key (safe to expose).
# Retrieve from: Supabase Dashboard → Project Settings → API → Project API keys → anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# Supabase — Server-side only (never expose to the browser)
# -----------------------------------------------------------------------------
# Your Supabase service role key (full database access — keep secret).
# Retrieve from: Supabase Dashboard → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase database connection string (used by Drizzle / migrations).
# Local:  postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Cloud:  postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# -----------------------------------------------------------------------------
# GitHub OAuth — Supabase Auth provider
# -----------------------------------------------------------------------------
# Create a GitHub OAuth App at https://github.com/settings/developers
# Set the Authorization callback URL to:
#   Local:  http://127.0.0.1:54321/auth/v1/callback
#   Cloud:  https://<project-ref>.supabase.co/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=your-github-client-id-here
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=your-github-client-secret-here

# -----------------------------------------------------------------------------
# Expo (Mobile) — Public (safe to expose)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
