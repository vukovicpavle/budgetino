# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# Project URL — found in Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
# Base URL used for absolute links (e.g. in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
