{
  "name": "mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "expo export --platform all --output-dir expo-dist",
    "eas-build:development": "pnpm exec eas build --profile development",
    "eas-build:preview": "pnpm exec eas build --profile preview",
    "eas-build:production": "pnpm exec eas build --profile production",
    "type-check": "tsc --noEmit",
    "clean": "rimraf .expo expo-dist"
  },
  "dependencies": {
    "expo": "~55.0.0",
    "expo-constants": "~17.0.8",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.77.3",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.3.1",
    "eas-cli": "^18.4.0",
    "rimraf": "^5.0.10",
    "typescript": "^5.7.3"
  }
}
