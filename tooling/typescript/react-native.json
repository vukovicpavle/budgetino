{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Native / Expo",
  "extends": "./base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "preserve",
    "moduleDetection": "force",
    "customConditions": ["react-native"],
    "target": "ESNext"
  }
}
